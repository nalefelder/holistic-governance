# Required — the server refuses to start without these.
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_PASS_HASH=$2b$10$your-bcrypt-hash-here

# Optional
ADMIN_USER=admin
HG_SITE_PATH=C:/path/to/holistic-governance

# Single-admin MFA (Essential Eight). When set, login requires a 6-digit
# authenticator code in addition to the password. Generate with: node generate-mfa.js
# Ignored once per-user accounts (admin-users.json) exist.
ADMIN_TOTP_SECRET=

# Optional override for the per-user admin store location (default: ./admin-users.json).
# Manage accounts with: node manage-users.js add <username>
# ADMIN_USERS_FILE=

# Set to true when served over HTTPS (enables Secure cookies + HSTS;
# also turns on trust proxy for reverse-proxy setups).
SECURE_COOKIES=false

# Comma-separated origins allowed to make state-changing requests (CSRF guard).
# Defaults to http://localhost:3000. Set to your real domain in production,
# e.g. https://admin.hg-au.com
ALLOWED_ORIGINS=http://localhost:3000
